<div class="cosmic-background-shell" aria-hidden="true" transition:persist>
  <canvas id="cosmic-canvas"></canvas>
</div>

<script>
  class CosmicBackgroundController {
    constructor(canvas) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d', { alpha: false });
      this.width = 0;
      this.height = 0;
      this.particles = [];
      this.frameId = 0;
      this.resizeObserver = null;
      this.config = {
        particleCount: 1500,
        pixelSize: 2,
        rotationSpeed: 0.0002,
        expansion: 1.5,
        arms: 3,
        armWidth: 0.4,
      };
      this.animate = this.animate.bind(this);
      this.resize = this.resize.bind(this);
    }

    attach(canvas) {
      if (this.canvas === canvas) return;
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d', { alpha: false });
      this.observeCanvas();
      this.handleResize();
    }

    Particle = class {
      constructor(controller) {
        const { width, height, config } = controller;
        const r = Math.random();
        const distance = Math.pow(r, config.expansion) * (Math.max(width, height) * 0.8);
        const armAngle = (Math.floor(Math.random() * config.arms) / config.arms) * Math.PI * 2;
        const twist = distance * 0.002;
        const dispersion = (Math.random() - 0.5) * config.armWidth * distance;

        this.baseAngle = armAngle + twist;
        this.distance = distance + dispersion;
        this.size = Math.floor(Math.random() * 2) === 0 ? config.pixelSize : config.pixelSize * 2;
        this.baseAlpha = (1 - this.distance / (Math.max(width, height) * 0.6)) * 0.8;
        this.baseAlpha = this.baseAlpha < 0 ? 0.1 : this.baseAlpha;
        this.blinkRate = Math.random() * 0.02;
        this.blinkPhase = Math.random() * Math.PI * 2;
      }

      draw(controller, time) {
        const { ctx, width, height, config } = controller;
        const speedMod = 1 / (1 + this.distance * 0.001);
        const currentAngle = this.baseAngle + time * config.rotationSpeed * speedMod;
        const x = width / 2 + Math.cos(currentAngle) * this.distance;
        const y = height / 2 + Math.sin(currentAngle) * this.distance;

        if (x > 0 && x < width && y > 0 && y < height) {
          const currentAlpha =
            this.baseAlpha * (0.7 + 0.3 * Math.sin(time * this.blinkRate + this.blinkPhase));

          const pixelX = Math.floor(x / this.size) * this.size;
          const pixelY = Math.floor(y / this.size) * this.size;

          ctx.fillStyle = `rgba(255, 255, 255, ${currentAlpha})`;
          ctx.fillRect(pixelX, pixelY, this.size, this.size);
        }
      }
    };

    initParticles() {
      this.particles = [];
      for (let i = 0; i < this.config.particleCount; i += 1) {
        this.particles.push(new this.Particle(this));
      }
    }

    handleResize() {
      if (!(this.canvas instanceof HTMLCanvasElement) || !this.ctx) return;

      const rect = this.canvas.getBoundingClientRect();
      const nextWidth = Math.max(1, Math.round(rect.width));
      const nextHeight = Math.max(1, Math.round(rect.height));

      if (nextWidth === this.width && nextHeight === this.height) return;

      this.width = nextWidth;
      this.height = nextHeight;
      this.canvas.width = nextWidth;
      this.canvas.height = nextHeight;
      this.initParticles();
    }

    observeCanvas() {
      if (this.resizeObserver) {
        this.resizeObserver.disconnect();
      }

      if ('ResizeObserver' in window) {
        this.resizeObserver = new ResizeObserver(() => this.handleResize());
        this.resizeObserver.observe(this.canvas);
      }

      window.removeEventListener('resize', this.handleResize);
      window.addEventListener('resize', this.handleResize, { passive: true });
    }

    animate(time) {
      this.ctx.fillStyle = '#000000';
      this.ctx.fillRect(0, 0, this.width, this.height);

      for (const particle of this.particles) {
        particle.draw(this, time);
      }

      this.frameId = window.requestAnimationFrame(this.animate);
    }

    start() {
      if (this.frameId) return;
      this.observeCanvas();
      this.handleResize();
      this.frameId = window.requestAnimationFrame(this.animate);
    }
  }

  const canvas = document.getElementById('cosmic-canvas');

  if (canvas instanceof HTMLCanvasElement) {
    const cosmicState = window.__cosmicBackgroundState;

    if (cosmicState?.controller) {
      cosmicState.controller.attach(canvas);
      cosmicState.controller.start();
    } else {
      const controller = new CosmicBackgroundController(canvas);
      window.__cosmicBackgroundState = { controller };
      controller.start();
    }
  }
</script>
