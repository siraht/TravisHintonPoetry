---
import poems from '../../data/poems.generated.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, renderPoemHtml } from '../../lib/poetry.js';
import SiteBrand from '../../components/SiteBrand.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export function getStaticPaths() {
  return poems.map((poem, index) => ({
    params: { slug: poem.slug },
    props: {
      poem,
      previous: poems[index + 1] ?? null,
      next: poems[index - 1] ?? null,
    },
  }));
}

const { poem, previous, next } = Astro.props;
const poemHtml = renderPoemHtml(poem.body);
---

<BaseLayout title={`${poem.title} | Travis Hinton Poetry`} description={poem.excerpt}>
  <div class="ambient-noise" aria-hidden="true"></div>

  <div class="detail-page-wrapper">
    <header class="site-header poem-header">
      <SiteBrand />
    </header>

    <main id="main" class="poem-page">
      <section class="poem-meta">
        <p class="eyebrow">Poem</p>
        <h1>{poem.title}</h1>
        <p>{formatDate(poem.sourceCreated)}</p>
      </section>

      <article class="poem-body" set:html={poemHtml}></article>
    </main>

    <SiteFooter previous={previous} next={next} className="detail-footer" />
  </div>
</BaseLayout>
