---
import poems from '../data/poems.generated.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate } from '../lib/poetry.js';
import { getAllTags } from '../lib/tags.js';
import SiteBrand from '../components/SiteBrand.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TagFilters from '../components/TagFilters.astro';

const poemCount = poems.length;
const tags = getAllTags(poems);
---

<BaseLayout>
  <div class="ambient-noise" aria-hidden="true"></div>
  <div class="page-wrapper home-page">
    <header class="home-sidebar">
      <SiteBrand />
      <TagFilters tags={tags} />
    </header>

    <main id="main" class="home-main">
      {poemCount === 0 ? (
        <div class="empty-state home-empty-state">
          <p>No poems are published yet.</p>
          <p>Add both <code>[[My Poetry]]</code> and <code>PoetrySite</code> to a note’s frontmatter, then run the sync.</p>
        </div>
      ) : (
        <ol class="poem-index-list" aria-label="Published poems">
          {poems.map((poem) => (
            <li class:list={['poem-item', { 'is-favorite': poem.favorite }]}>
              <a class="poem-link" href={`/poems/${poem.slug}/`}>
                {poem.title}
              </a>
              <span class="poem-item-meta">
                {poem.favorite && <span>Favorite // </span>}
                {formatDate(poem.sourceCreated)}
              </span>
            </li>
          ))}
        </ol>
      )}
    </main>
  </div>

  <SiteFooter className="home-footer" />
</BaseLayout>
